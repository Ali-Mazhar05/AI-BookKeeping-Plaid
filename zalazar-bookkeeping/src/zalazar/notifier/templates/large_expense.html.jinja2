{% extends "base_email.html.jinja2" %}

{% block content %}
    <div class="alert-box alert-warning">
        <strong>Large Expense Detected</strong>
    </div>
    
    <p>Hello,</p>
    
    <p>A significant expense has been flagged on your account that exceeds your notification threshold.</p>
    
    <div style="background-color: #f8fafc; padding: 20px; border-radius: 12px; margin: 24px 0;">
        <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
                <td style="color: #64748b; font-size: 14px; padding-bottom: 8px;">Vendor</td>
                <td style="text-align: right; font-weight: 600; padding-bottom: 8px;">{{ vendor }}</td>
            </tr>
            <tr>
                <td style="color: #64748b; font-size: 14px; padding-bottom: 8px;">Amount</td>
                <td style="text-align: right; font-weight: 700; color: #e11d48; font-size: 18px;">${{ amount }}</td>
            </tr>
            {% if date %}
            <tr>
                <td style="color: #64748b; font-size: 14px;">Date</td>
                <td style="text-align: right; font-weight: 600;">{{ date }}</td>
            </tr>
            {% endif %}
        </table>
    </div>

    <p>Please review this transaction to ensure it is categorized correctly and attributed to the proper property.</p>

    <a href="{{ dashboard_url }}" class="button">Review in Dashboard</a>
{% endblock %}
