{% extends "base_email.html.jinja2" %}

{% block content %}
    <div class="alert-box" style="background-color: #f0fdf4; border-left: 4px solid #22c55e; color: #166534;">
        <strong>Income Received</strong>
    </div>
    
    <p>Good news! New income has been detected on your account.</p>
    
    <div style="background-color: #f8fafc; padding: 20px; border-radius: 12px; margin: 24px 0;">
        <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
                <td style="color: #64748b; font-size: 14px; padding-bottom: 8px;">Source</td>
                <td style="text-align: right; font-weight: 600; padding-bottom: 8px;">{{ source }}</td>
            </tr>
            <tr>
                <td style="color: #64748b; font-size: 14px; padding-bottom: 8px;">Amount</td>
                <td style="text-align: right; font-weight: 700; color: #15803d; font-size: 18px;">${{ amount }}</td>
            </tr>
            {% if date %}
            <tr>
                <td style="color: #64748b; font-size: 14px;">Date</td>
                <td style="text-align: right; font-weight: 600;">{{ date }}</td>
            </tr>
            {% endif %}
        </table>
    </div>

    <p>This transaction has been recorded. You can view the details and allocation in your dashboard.</p>

    <div style="text-align: center;">
        <a href="{{ dashboard_url }}" class="button">View Dashboard</a>
    </div>
{% endblock %}
